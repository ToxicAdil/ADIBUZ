# ─── Testing & coverage ───────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Certificates & keys (never commit) ──────────────────────────────────────
*.pem
*.p12
*.pfx
*.key
*.cert
*.crt

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── Large media (stored in Cloudinary, not git) ──────────────────────────────
public/videos/*.mp4
public/videos/*.webm
public/videos/*.mov

# ─── Temp / scratch ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
